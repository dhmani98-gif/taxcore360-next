// TaxCore360 Database Schema
// Railway + Supabase PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════════════════════════════════
// Core Models
// ═══════════════════════════════════════════════════════════

model Company {
  id          String    @id @default(cuid())
  ein         String    @unique
  legalName   String
  dbaName     String?
  address     String?
  city        String?
  state       String?
  zipCode     String?
  phone       String?
  email       String?
  
  // Relations
  users       User[]
  employees   Employee[]
  vendors     Vendor[]
  payments    Payment[]
  payrolls    Payroll[]
  taxForms    TaxForm[]
  auditLogs   AuditLog[]
  documents   VaultDocument[]
  w9Invites   W9Invite[]
  w9Submissions W9Submission[]
  subscription CompanySubscription?
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("companies")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  avatarUrl     String?
  role          Role      @default(OPERATIONS_MANAGER)
  
  // Supabase Auth - store supabase user id
  supabaseUid   String?   @unique
  
  // MFA
  mfaEnabled    Boolean   @default(false)
  mfaSecret     String?   // Encrypted TOTP secret
  
  // Relations
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  auditLogs     AuditLog[]
  notifications Notification[]
  
  // Notification preferences
  emailNotifications Boolean @default(true)
  smsNotifications   Boolean @default(false)
  phoneNumber        String?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("users")
}

// ═══════════════════════════════════════════════════════════
// Employee Management
// ═══════════════════════════════════════════════════════════

model Employee {
  id          String   @id @default(cuid())
  
  // Personal Info (PII - Encrypted)
  ssn         String   // Encrypted at application level
  ssnHash     String   @unique // SHA256 for lookup
  
  firstName   String
  lastName    String
  fullName    String
  
  // Address
  address     String?
  city        String?
  state       String?
  zipCode     String?
  
  // Employment
  department  String?
  jobTitle    String?
  hireDate    DateTime?
  terminationDate DateTime?
  
  // Compensation
  grossPay    Decimal  @default(0) @db.Decimal(12, 2)
  salary      Decimal? @db.Decimal(12, 2)
  hourlyRate  Decimal? @db.Decimal(8, 2)
  
  // Status
  status      EmployeeStatus @default(ACTIVE)
  isExempt    Boolean @default(false) // FLSA exempt status
  
  // Relations
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  payrolls    Payroll[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId, status])
  @@map("employees")
}

model Payroll {
  id                   String   @id @default(cuid())
  
  // Pay Period
  payPeriod            String   // e.g., "2024-01-01 to 2024-01-15"
  payDate              DateTime
  
  // Hours
  regularHours         Decimal  @default(0) @db.Decimal(8, 2)
  overtimeHours        Decimal  @default(0) @db.Decimal(8, 2)
  
  // Earnings
  regularPay           Decimal  @db.Decimal(12, 2)
  overtimePay          Decimal  @default(0) @db.Decimal(12, 2)
  grossPay             Decimal  @db.Decimal(12, 2)
  
  // Federal Taxes
  federalWithholding   Decimal  @db.Decimal(12, 2)
  socialSecurity       Decimal  @db.Decimal(12, 2)
  medicare             Decimal  @db.Decimal(12, 2)
  
  // State & Local
  stateTax             Decimal  @default(0) @db.Decimal(12, 2)
  localTax             Decimal  @default(0) @db.Decimal(12, 2)
  
  // Deductions
  pretaxDeductions     Decimal  @default(0) @db.Decimal(12, 2) // 401k, Health, etc.
  posttaxDeductions    Decimal  @default(0) @db.Decimal(12, 2)
  
  // Net
  netPay               Decimal  @db.Decimal(12, 2)
  
  // Relations
  employeeId           String
  employee             Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  companyId            String
  company              Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([companyId, payDate])
  @@index([employeeId, payDate])
  @@map("payrolls")
}

// ═══════════════════════════════════════════════════════════
// 1099 Vendor Management
// ═══════════════════════════════════════════════════════════

model Vendor {
  id                String    @id @default(cuid())
  vendorId          String    @unique // Internal ID
  
  // Tax Info (PII - Encrypted)
  taxId             String    // EIN or SSN - Encrypted
  taxIdHash         String    @unique // For lookup
  taxIdType         TaxIdType
  
  // IRS Verification
  tinVerified       Boolean   @default(false)
  tinVerifiedAt     DateTime?
  tinMatchName      String?   // Name that matched with TIN
  tinVerificationCode String? // IRS response code
  
  // Business Info
  legalName         String
  dbaName           String?
  entityType        EntityType
  
  // Address
  address           String
  address2          String?
  city              String?
  state             String
  zipCode           String?
  
  // Contact
  email             String?
  phone             String?
  
  // W-9 Management
  w9Requested       Boolean   @default(false)
  w9RequestedAt     DateTime?
  w9Received        Boolean   @default(false)
  w9ReceivedAt      DateTime?
  w9FileUrl         String?   // Supabase Storage path
  
  // Relations
  companyId         String
  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  payments          Payment[]
  documents         VaultDocument[]
  w9Invites         W9Invite[]
  w9Submissions     W9Submission[]
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([companyId, tinVerified])
  @@map("vendors")
}

model VaultDocument {
  id          String  @id @default(cuid())

  category    DocumentCategory
  documentName String
  notes       String? @db.Text

  fileUrl     String
  fileType    String
  fileSize    Int
  storagePath String

  // Relations
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vendorId    String?
  vendor      Vendor? @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())

  @@index([companyId, category, createdAt])
  @@index([vendorId, createdAt])
  @@map("vault_documents")
}

model W9Invite {
  id          String  @id @default(cuid())
  token       String  @unique
  status      W9InviteStatus @default(SENT)

  vendorEmail String?

  viewedAt    DateTime?
  completedAt DateTime?

  // Relations
  companyId   String
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vendorId    String?
  vendor      Vendor? @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  submissions W9Submission[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId, status, createdAt])
  @@index([vendorId, createdAt])
  @@map("w9_invites")
}

model W9Submission {
  id            String  @id @default(cuid())
  approvalStatus W9ApprovalStatus @default(PENDING)

  // W-9 snapshot fields
  legalName     String
  email         String?
  address       String?
  state         String?
  taxIdType     TaxIdType
  taxId         String
  entityType    EntityType

  eSigned       Boolean @default(false)
  signatureName String?
  signatureDate DateTime?

  submittedAt   DateTime @default(now())
  reviewedAt    DateTime?
  reviewNotes   String? @db.Text

  // Relations
  companyId     String
  company       Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vendorId      String?
  vendor        Vendor? @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  inviteId      String
  invite        W9Invite @relation(fields: [inviteId], references: [id], onDelete: Cascade)

  @@index([companyId, approvalStatus, submittedAt])
  @@index([vendorId, submittedAt])
  @@index([inviteId])
  @@map("w9_submissions")
}

model SubscriptionPlan {
  id          String  @id
  name        String
  priceCents  Int
  interval    SubscriptionInterval
  isActive    Boolean @default(true)
  isPopular   Boolean @default(false)
  features    Json

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions CompanySubscription[]

  @@map("subscription_plans")
}

model CompanySubscription {
  id          String  @id @default(cuid())
  status      SubscriptionStatus @default(ACTIVE)

  seats       Int     @default(1)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean @default(false)

  // Relations
  companyId   String  @unique
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  planId      String
  plan        SubscriptionPlan @relation(fields: [planId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, currentPeriodEnd])
  @@map("company_subscriptions")
}

model Payment {
  id               String   @id @default(cuid())
  
  amount           Decimal  @db.Decimal(12, 2)
  paymentDate      DateTime
  
  // Invoice
  invoiceNumber    String?
  invoiceDate      DateTime?
  description      String?  @db.Text
  
  // 1099 Reporting
  is1099Reportable Boolean  @default(true)
  box7Nec          Decimal  @default(0) @db.Decimal(12, 2) // Nonemployee comp
  box1Misc         Decimal  @default(0) @db.Decimal(12, 2) // Rents
  box2Misc         Decimal  @default(0) @db.Decimal(12, 2) // Royalties
  box3Misc         Decimal  @default(0) @db.Decimal(12, 2) // Other income
  box6Misc         Decimal  @default(0) @db.Decimal(12, 2) // Medical payments
  
  // Payment Method
  paymentMethod    PaymentMethod @default(CHECK)
  checkNumber      String?
  
  // Relations
  vendorId         String
  vendor           Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  companyId        String
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  attachments      Attachment[]
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([companyId, paymentDate])
  @@index([vendorId, paymentDate])
  @@map("payments")
}

model Attachment {
  id          String  @id @default(cuid())
  
  fileName    String
  fileUrl     String   // Supabase Storage signed URL
  fileType    String   // MIME type
  fileSize    Int      // Bytes
  storagePath String   // Supabase Storage path
  
  // OCR Data
  ocrText     String?  @db.Text
  ocrConfidence Decimal? @db.Decimal(5, 2)
  
  // Relations
  paymentId   String
  payment     Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())

  @@map("attachments")
}

// ═══════════════════════════════════════════════════════════
// Tax Forms
// ═══════════════════════════════════════════════════════════

model TaxForm {
  id             String     @id @default(cuid())
  
  // Form Info
  type           FormType
  year           Int
  
  // Status
  status         FormStatus @default(DRAFT)
  
  // Recipient
  recipientType  RecipientType
  recipientId    String      // employeeId or vendorId (polymorphic)
  
  // Form Specific Fields
  copyType       CopyType?   // For 1099: CopyA | CopyB | CopyC
  
  // Amounts
  totalAmount    Decimal    @db.Decimal(12, 2)
  federalWithheld Decimal   @default(0) @db.Decimal(12, 2)
  
  // State Info
  stateCode      String?
  stateIdNumber  String?
  stateWithheld  Decimal    @default(0) @db.Decimal(12, 2)
  
  // Files (Supabase Storage)
  pdfUrl         String?
  xmlUrl         String?    // IRS XML format
  txtUrl         String?    // Publication 1220 format
  
  // Filing
  filedWith      FilingMethod?
  submittedAt    DateTime?
  acceptedAt     DateTime?
  
  // Corrections
  isCorrection   Boolean    @default(false)
  correctionSeq  Int        @default(0) // 0 = original, 1+ = corrections
  originalFormId String?    // Reference to original form
  
  // Rejection
  rejectionCode  String?
  rejectionReason String?
  
  // Relations
  companyId      String
  company        Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([companyId, type, year])
  @@index([companyId, status])
  @@index([recipientId, year])
  @@map("tax_forms")
}

// ═══════════════════════════════════════════════════════════
// Audit & Compliance
// ═══════════════════════════════════════════════════════════

model AuditLog {
  id         String   @id @default(cuid())
  
  action     AuditAction
  
  // Actor
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  ipAddress  String?
  userAgent  String?
  
  // Target
  entityType AuditEntityType
  entityId   String
  
  // Changes
  oldValues  Json?
  newValues  Json?
  
  // Metadata
  metadata   Json?    // Additional context
  
  // Relations
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  createdAt  DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([entityType, entityId])
  @@index([userId, createdAt])
  @@map("audit_logs")
}

// ═══════════════════════════════════════════════════════════
// Notifications
// ═══════════════════════════════════════════════════════════

model Notification {
  id        String   @id @default(cuid())
  
  type      NotificationType
  channel   NotificationChannel
  priority  NotificationPriority @default(NORMAL)
  
  title     String
  message   String   @db.Text
  data      Json?    // Additional context
  
  // Status
  read      Boolean  @default(false)
  readAt    DateTime?
  
  // Delivery
  sentAt    DateTime?
  deliveredAt DateTime?
  
  // Relations
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())

  @@index([userId, read, createdAt])
  @@index([userId, channel, createdAt])
  @@map("notifications")
}

model TaxDeadline {
  id          String   @id @default(cuid())
  
  formType    FormType
  year        Int
  dueDate     DateTime
  
  description String
  penaltyAmount Decimal? @db.Decimal(12, 2)
  
  // Scope
  isFederal   Boolean  @default(true)
  state       String?  // null = federal
  
  // Reminders sent
  reminder30Sent Boolean @default(false)
  reminder14Sent Boolean @default(false)
  reminder7Sent  Boolean @default(false)
  reminder1Sent  Boolean @default(false)
  
  createdAt   DateTime @default(now())

  @@unique([formType, year, state])
  @@map("tax_deadlines")
}

// ═══════════════════════════════════════════════════════════
// Settings & Configuration
// ═══════════════════════════════════════════════════════════

model CompanySetting {
  id          String   @id @default(cuid())
  
  companyId   String   @unique
  
  // Payroll Settings
  payPeriodType String @default("BIWEEKLY") // WEEKLY, BIWEEKLY, SEMIMONTHLY, MONTHLY
  payDay        Int    @default(5) // Day of week/month
  
  // Tax Settings
  depositSchedule String @default("MONTHLY") // MONTHLY, SEMIWEEKLY
  lookbackPeriod  DateTime?
  
  // 1099 Settings
  necThreshold    Decimal @default(600) @db.Decimal(12, 2)
  miscThreshold   Decimal @default(600) @db.Decimal(12, 2)
  
  // Integrations
  quickbooksConnected Boolean @default(false)
  quickbooksRealmId   String?
  
  // Notifications
  defaultEmailTemplate String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("company_settings")
}

// ═══════════════════════════════════════════════════════════
// Enums
// ═══════════════════════════════════════════════════════════

enum Role {
  ADMIN
  MANAGER
  OPERATIONS_MANAGER
  ACCOUNTANT
  PAYROLL_SPECIALIST
  USER
  VIEWER
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  TERMINATED
  ON_LEAVE
  SUSPENDED
}

enum TaxIdType {
  EIN
  SSN
  ITIN
}

enum EntityType {
  INDIVIDUAL
  SOLE_PROPRIETORSHIP
  LLC_SINGLE_MEMBER
  LLC_PARTNERSHIP
  LLC_C_CORP
  LLC_S_CORP
  C_CORPORATION
  S_CORPORATION
  PARTNERSHIP
  TRUST
  ESTATE
  NONPROFIT
}

enum PaymentMethod {
  CASH
  CHECK
  ACH
  WIRE
  CREDIT_CARD
  DEBIT_CARD
  PAYPAL
  OTHER
}

enum FormType {
  W2
  W3
  NEC1099
  MISC1099
  INT1099
  DIV1099
  R1099
  B1099
  K1099
  SA1099
  FORM940
  FORM941
  FORM943
  FORM944
  FORM945
  CT1
}

enum FormStatus {
  DRAFT
  GENERATED
  REVIEW_PENDING
  APPROVED
  SUBMITTED
  ACCEPTED
  REJECTED
  CORRECTED
  VOID
}

enum RecipientType {
  EMPLOYEE
  VENDOR
  CONTRACTOR
  OTHER
}

enum CopyType {
  COPY_A
  COPY_B
  COPY_C
  COPY_1
  COPY_2
  STATE
}

enum FilingMethod {
  EFILE
  PAPER
  THIRD_PARTY // Track1099, Tax1099, etc.
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  VIEW
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
  GENERATE
  SUBMIT
  DOWNLOAD
  PRINT
  VOID
  CORRECT
  VERIFY
  APPROVE
  REJECT
}

enum AuditEntityType {
  EMPLOYEE
  VENDOR
  PAYMENT
  PAYROLL
  TAX_FORM
  COMPANY
  USER
  SETTING
  ATTACHMENT
}

enum NotificationType {
  EMAIL
  SMS
  IN_APP
  PUSH
}

enum NotificationChannel {
  DEADLINE
  FILING
  SYSTEM
  SECURITY
  PAYMENT
  REMINDER
  APPROVAL
  ERROR
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum DocumentCategory {
  W9
  INVOICE
  CONTRACT
  RECEIPT
  TAX_DOCUMENT
  CORRESPONDENCE
  COMPLIANCE
  OTHER
}

enum W9InviteStatus {
  SENT
  VIEWED
  COMPLETED
  EXPIRED
  CANCELED
}

enum W9ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SubscriptionInterval {
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  TRIALING
}
